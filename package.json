{
  "name": "flash-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "tsc -b",
    "smoke": "npm run build && node scripts/smoke-check.mjs",
    "audit": "node scripts/submission-audit.mjs",
    "product-check": "node scripts/product-check.mjs",
    "privacy": "node scripts/privacy-check.mjs",
    "verify": "npm run check && npm run smoke && npm run audit && npm run product-check && npm run privacy",
    "live-check": "node scripts/live-check.mjs",
    "deploy": "npm run build && wrangler pages deploy dist --project-name flash-arena"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^4.100.0"
  }
}
